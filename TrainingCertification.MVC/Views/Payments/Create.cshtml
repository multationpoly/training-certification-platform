@model TrainingCertification.API.Models.Payment
<h1 class="h3">Record Payment</h1>
<form method="post" class="card p-4 shadow-sm">
    <div asp-validation-summary="All" class="text-danger"></div>
    <input asp-for="EnrollmentId" type="hidden" />
    <label asp-for="Amount" class="form-label"></label>
    <input asp-for="Amount" class="form-control mb-3" />
    <label asp-for="Method" class="form-label"></label>
    <select asp-for="Method" class="form-select mb-3">
        <option>Cash</option>
        <option>Card</option>
        <option>Bank Transfer</option>
        <option>BenefitPay</option>
    </select>
    <label asp-for="Status" class="form-label"></label>
    <select asp-for="Status" class="form-select mb-3" asp-items="Html.GetEnumSelectList<TrainingCertification.API.Models.PaymentStatus>()"></select>
    <label asp-for="Notes" class="form-label"></label>
    <textarea asp-for="Notes" class="form-control mb-3"></textarea>
    <button class="btn btn-primary">Save</button>
</form>
