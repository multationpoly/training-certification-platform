@model TrainingCertification.MVC.ViewModels.CourseFormViewModel
@using TrainingCertification.API.Models
@{
    var isEdit = Model.Course.Id > 0;
    ViewData["Title"] = isEdit ? "Edit Course" : "Create Course";
}

<h1 class="h3">@(isEdit ? "Edit Course" : "Create Course")</h1>
<form method="post" class="card p-4 shadow-sm">
    <div asp-validation-summary="All" class="text-danger"></div>
    <input asp-for="Course.Id" type="hidden" />
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Course.Title" class="form-label"></label>
            <input asp-for="Course.Title" class="form-control" />
        </div>
        <div class="col-md-6">
            <label asp-for="Course.CourseCategoryId" class="form-label">Category</label>
            <select asp-for="Course.CourseCategoryId" class="form-select" asp-items="@(new SelectList(Model.Categories, "Id", "Name"))"></select>
        </div>
        <div class="col-12">
            <label asp-for="Course.Description" class="form-label"></label>
            <textarea asp-for="Course.Description" class="form-control" rows="3"></textarea>
        </div>
        <div class="col-md-3">
            <label asp-for="Course.DurationDays" class="form-label"></label>
            <input asp-for="Course.DurationDays" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Course.Capacity" class="form-label"></label>
            <input asp-for="Course.Capacity" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Course.EnrollmentFee" class="form-label"></label>
            <input asp-for="Course.EnrollmentFee" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Course.RequiredEquipment" class="form-label">Required Equipment</label>
            <input asp-for="Course.RequiredEquipment" class="form-control" placeholder="Projector, Workstations" />
        </div>
        <div class="col-md-3">
            <label asp-for="PrerequisiteCourseId" class="form-label"></label>
            <select asp-for="PrerequisiteCourseId" class="form-select" asp-items="@(new SelectList(Model.AvailablePrerequisites, "Id", "Title"))">
                <option value="">None</option>
            </select>
        </div>
        <div class="col-12">
            <div class="form-check">
                <input asp-for="Course.IsActive" class="form-check-input" />
                <label asp-for="Course.IsActive" class="form-check-label"></label>
            </div>
        </div>
    </div>
    <div class="d-flex gap-2 mt-4">
        <button class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
