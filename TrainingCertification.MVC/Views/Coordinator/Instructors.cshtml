@model IEnumerable<InstructorProfile>
@{
    ViewData["Title"] = "Instructors";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Instructors</h1>
    <a asp-action="CreateInstructor" class="btn btn-primary">Create Instructor Account</a>
</div>
<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead><tr><th>Name</th><th>Email</th><th>Expertise</th><th>Availability</th><th>Sessions</th><th></th></tr></thead>
        <tbody>
        @foreach (var instructor in Model)
        {
            <tr>
                <td>@instructor.FullName</td>
                <td>@instructor.ApplicationUser?.Email</td>
                <td>@string.Join(", ", instructor.Expertises.Select(e => e.CourseCategory!.Name))</td>
                <td>@string.Join("; ", instructor.Availability.OrderBy(a => a.DayOfWeek).Select(a => $"{a.DayOfWeek} {a.StartTime:hh\\:mm}-{a.EndTime:hh\\:mm}"))</td>
                <td>@instructor.Sessions.Count</td>
                <td class="text-end"><a asp-action="EditInstructor" asp-route-id="@instructor.Id" class="btn btn-sm btn-outline-secondary">Manage</a></td>
            </tr>
        }
        </tbody>
    </table>
</div>
