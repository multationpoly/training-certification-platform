@model TrainingCertification.MVC.ViewModels.InstructorManagementViewModel
@{
    ViewData["Title"] = "Manage Instructor";
}
<h1 class="h3">Manage Instructor</h1>
<form asp-action="SaveInstructor" method="post" class="card p-4 shadow-sm">
    <input asp-for="Instructor.Id" type="hidden" />
    <label asp-for="Instructor.FullName" class="form-label"></label>
    <input asp-for="Instructor.FullName" class="form-control mb-3" />
    <label asp-for="Instructor.ExpertiseAreas" class="form-label"></label>
    <input asp-for="Instructor.ExpertiseAreas" class="form-control mb-3" />
    <label asp-for="Instructor.Bio" class="form-label"></label>
    <textarea asp-for="Instructor.Bio" class="form-control mb-3" rows="3"></textarea>

    <h2 class="h5">Subject Expertise</h2>
    <div class="row g-2 mb-3">
        @foreach (var category in Model.Categories)
        {
            <div class="col-md-4">
                <label class="form-check">
                    <input class="form-check-input" type="checkbox" name="SelectedCategoryIds" value="@category.Id" checked="@(Model.SelectedCategoryIds.Contains(category.Id))" />
                    <span class="form-check-label">@category.Name</span>
                </label>
            </div>
        }
    </div>

    <h2 class="h5">Weekly Availability</h2>
    <div class="row g-2">
        @for (var i = 0; i < Model.Availability.Count; i++)
        {
            <div class="col-lg-6">
                <div class="border rounded p-2">
                    <input asp-for="Availability[i].DayOfWeek" type="hidden" />
                    <label class="form-check mb-2">
                        <input asp-for="Availability[i].IsAvailable" class="form-check-input" />
                        <span class="form-check-label">@Model.Availability[i].DayOfWeek</span>
                    </label>
                    <div class="row g-2">
                        <div class="col"><input asp-for="Availability[i].StartTime" class="form-control" /></div>
                        <div class="col"><input asp-for="Availability[i].EndTime" class="form-control" /></div>
                    </div>
                </div>
            </div>
        }
    </div>
    <div class="d-flex gap-2 mt-4">
        <button class="btn btn-primary">Save</button>
        <a asp-action="Instructors" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
