@model List<(ApplicationUser User, IList<string> Roles)>
@{
    ViewData["Title"] = "Users";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Users</h1>
    <a class="btn btn-primary" asp-action="CreateInstructor">Create Instructor</a>
</div>
<div class="table-responsive">
    <table class="table table-striped">
        <thead><tr><th>Name</th><th>Email</th><th>Roles</th><th>Status</th></tr></thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.User.FullName</td>
                <td>@item.User.Email</td>
                <td>@string.Join(", ", item.Roles)</td>
                <td>@(item.User.LockoutEnd > DateTimeOffset.UtcNow ? "Inactive" : "Active")</td>
            </tr>
        }
        </tbody>
    </table>
</div>
